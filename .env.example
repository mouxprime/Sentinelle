# ==============================================================================
# OSINT AGGREGATOR - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control
# ==============================================================================

# ------------------------------------------------------------------------------
# DATABASE (REQUIRED)
# ------------------------------------------------------------------------------
POSTGRES_USER=osint
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=osint_aggregator
POSTGRES_PORT=5432

# ------------------------------------------------------------------------------
# REDIS
# ------------------------------------------------------------------------------
REDIS_PORT=6379

# ------------------------------------------------------------------------------
# LLM CONFIGURATION (REQUIRED)
# ------------------------------------------------------------------------------
# LM Studio API endpoint - default points to host machine
LLM_API_URL=http://host.docker.internal:1234/v1
# Model name loaded in LM Studio
LLM_MODEL=qwen2.5-7b-instruct

# ------------------------------------------------------------------------------
# MAPBOX (REQUIRED)
# ------------------------------------------------------------------------------
# Get your token at: https://account.mapbox.com/access-tokens/
MAPBOX_TOKEN=your_mapbox_token_here

# ------------------------------------------------------------------------------
# TELEGRAM CONFIGURATION (REQUIRED FOR TELEGRAM COLLECTION)
# ------------------------------------------------------------------------------
# Get your API credentials at: https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890
# Comma-separated list of channel usernames (without @)
TELEGRAM_CHANNELS=channel1,channel2,channel3

# ------------------------------------------------------------------------------
# RSS FEEDS (OPTIONAL)
# ------------------------------------------------------------------------------
# Comma-separated list of RSS feed URLs
RSS_FEEDS=https://example.com/feed1.xml,https://example.com/feed2.xml

# ------------------------------------------------------------------------------
# DISCORD BOT (OPTIONAL)
# ------------------------------------------------------------------------------
# DISCORD_BOT_TOKEN=your_discord_bot_token
# DISCORD_CHANNELS=channel_id_1,channel_id_2

# ------------------------------------------------------------------------------
# FLIGHTRADAR24 (OPTIONAL)
# ------------------------------------------------------------------------------
# FLIGHTRADAR_ENABLED=true
# Bounding box format: lat1,lon1,lat2,lon2
# FLIGHTRADAR_BOUNDS=40.0,-100.0,50.0,-90.0

# ------------------------------------------------------------------------------
# MARINETRAFFIC (OPTIONAL)
# ------------------------------------------------------------------------------
# MARINETRAFFIC_ENABLED=true
# MARINETRAFFIC_API_KEY=your_api_key_here

# ------------------------------------------------------------------------------
# SCHEDULER CONFIGURATION
# ------------------------------------------------------------------------------
# How often to collect data from sources (in minutes)
COLLECTION_INTERVAL_MINUTES=5
# How often to process collected events with LLM (in minutes)
PROCESSING_INTERVAL_MINUTES=2

# ------------------------------------------------------------------------------
# DOCKER PORTS
# ------------------------------------------------------------------------------
NGINX_PORT=80
AGGREGATOR_PORT=8000
